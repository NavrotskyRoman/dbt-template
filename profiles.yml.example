project_name:
  # Цель по умолчанию. Можно оставить одну (dev) или добавить prod.
  target: dev
  outputs:
    dev:
      type: bigquery
      # Используем JSON-ключ из переменной окружения, без локального файла.
      # Метод ДОЛЖЕН быть service-account-json вместе с keyfile_json.
      method: service-account-json

      # Обязательные параметры подключения
      project: "{{ env_var('DBT_BIGQUERY_PROJECT') }}"         # GCP project id
      dataset: "{{ env_var('DBT_BIGQUERY_DATASET') }}"         # базовый датасет (например 'staging' или 'raws' для dev)
      location: "{{ env_var('DBT_BIGQUERY_LOCATION', 'US') }}" # регион (US / EU и т.п.)

      # JSON содержимое service account (строка), передаётся через переменную окружения.
      # Рекомендуется использовать префикс DBT_ENV_SECRET_, чтобы значение не логировалось.
      keyfile_json: "{{ env_var('DBT_ENV_SECRET_BIGQUERY_KEYFILE_JSON') }}"

      # Технические настройки (опционально)
      threads: "{{ env_var('DBT_BIGQUERY_THREADS', '4') | int }}"
      timeout_seconds: "{{ env_var('DBT_BIGQUERY_TIMEOUT_SECONDS', '300') | int }}"
      priority: "{{ env_var('DBT_BIGQUERY_PRIORITY', 'interactive') }}"
      maximum_bytes_billed: "{{ env_var('DBT_BIGQUERY_MAX_BYTES_BILLED', '0') | int }}"  # 0 = без лимита

    # Пример второго таргета (prod) — при необходимости раскомментируйте и настройте.
    # prod:
    #   type: bigquery
    #   method: service-account-json
    #   project: "{{ env_var('DBT_BIGQUERY_PROJECT_PROD', env_var('DBT_BIGQUERY_PROJECT')) }}"
    #   dataset: "{{ env_var('DBT_BIGQUERY_DATASET_PROD') }}"
    #   location: "{{ env_var('DBT_BIGQUERY_LOCATION_PROD', env_var('DBT_BIGQUERY_LOCATION', 'US')) }}"
    #   keyfile_json: "{{ env_var('DBT_ENV_SECRET_BIGQUERY_KEYFILE_JSON_PROD', env_var('DBT_ENV_SECRET_BIGQUERY_KEYFILE_JSON')) }}"
    #   threads: "{{ env_var('DBT_BIGQUERY_THREADS_PROD', '8') | int }}"
    #   timeout_seconds: "{{ env_var('DBT_BIGQUERY_TIMEOUT_SECONDS_PROD', '600') | int }}"
    #   priority: "{{ env_var('DBT_BIGQUERY_PRIORITY_PROD', 'batch') }}"
    #   maximum_bytes_billed: "{{ env_var('DBT_BIGQUERY_MAX_BYTES_BILLED_PROD', '0') | int }}"

lp_crm:
  target: dev
  outputs:
    dev:
      type: bigquery
      method: service-account  # или oauth для gcloud auth
      keyfile: /path/to/your-service-account.json
      project: your-gcp-project-id
      dataset: dataset 
      location: US
      priority: interactive
      maximum_bytes_billed: 1000000000  # 1 GB

    prod:
      type: bigquery
      method: service-account
      keyfile: /path/to/your-service-account.json
      project: your-gcp-project-id
      dataset: dataset 
      location: US
      priority: batch
      maximum_bytes_billed: 10000000000  # 10 GB
