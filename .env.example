# dbt-template (BigQuery). Копировать в .env. Секреты не коммитить.
# Ключ для BigQuery: скрипт scripts/configs/google_secret_to_base64.sh — ввод из файла, вывод вставить ниже.

DBT_PROJECT_NAME=project_name

# --- dev ---
DBT_BIGQUERY_PROJECT=your-gcp-project-id
DBT_BIGQUERY_DATASET=no_schema
DBT_BIGQUERY_LOCATION=europe-west3
DBT_BIGQUERY_THREADS=4
DBT_BIGQUERY_TIMEOUT_SECONDS=300
DBT_BIGQUERY_PRIORITY=interactive
DBT_BIGQUERY_MAX_BYTES_BILLED=0
# Только base64 (одна строка, без пробелов/переносов). См. scripts/configs/google_secret_to_base64.sh
DBT_ENV_SECRET_BIGQUERY_KEYFILE_BASE64=

# --- prod (раскомментировать таргет prod в profiles.yml) ---
# DBT_BIGQUERY_PROJECT_PROD=
# DBT_BIGQUERY_DATASET_PROD=
# DBT_BIGQUERY_LOCATION_PROD=
# DBT_BIGQUERY_THREADS_PROD=8
# DBT_BIGQUERY_TIMEOUT_SECONDS_PROD=600
# DBT_BIGQUERY_PRIORITY_PROD=batch
# DBT_BIGQUERY_MAX_BYTES_BILLED_PROD=0
# DBT_ENV_SECRET_BIGQUERY_KEYFILE_BASE64_PROD=
