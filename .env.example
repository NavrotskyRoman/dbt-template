##############################################
# Пример .env для dbt-template (BigQuery)
#
# Этот файл НЕ должен содержать реальные секреты в репозитории.
# Скопируйте его в .env и подставьте свои значения локально / в CI.
##############################################

# Имя проекта dbt (должно совпадать с name/profile в dbt_project.yml)
DBT_PROJECT_NAME=project_name

######## BigQuery (общие параметры) ########

# GCP project id
DBT_BIGQUERY_PROJECT=your-gcp-project-id

# Базовый датасет по умолчанию (например, staging для dev)
DBT_BIGQUERY_DATASET=staging

# Регион BigQuery (US, EU и т.д.)
DBT_BIGQUERY_LOCATION=europe-west3

# Количество потоков dbt (параллельных моделей)
DBT_BIGQUERY_THREADS=4

# Таймаут запросов в секундах
DBT_BIGQUERY_TIMEOUT_SECONDS=300

# Приоритет запросов: interactive | batch
DBT_BIGQUERY_PRIORITY=interactive

# Ограничение на стоимость запросов (в байтах), 0 = без лимита
DBT_BIGQUERY_MAX_BYTES_BILLED=0

######## BigQuery credential (секрет) ########

# JSON содержимое service account, целиком как одна строка.
# Задавать переменную только в локальной среде / Secret Manager / CI,
# а НЕ коммитить в git.
#
# Пример (НЕ на проде, только для теста):
# DBT_ENV_SECRET_BIGQUERY_KEYFILE_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n..."}'
DBT_ENV_SECRET_BIGQUERY_KEYFILE_JSON=

##############################################
# Профиль "domain" (замените domain на имя вашего домена, например lp_crm)
# Используется, если в dbt_project.yml указан profile: domain.
##############################################

# GCP project id
DBT_DOMAIN_BIGQUERY_PROJECT=your-gcp-project-id

# Базовый датасет (например, staging для dev)
DBT_DOMAIN_BIGQUERY_DATASET=staging

# Регион BigQuery
DBT_DOMAIN_BIGQUERY_LOCATION=europe-west3

# Опционально: threads, timeout_seconds, priority, maximum_bytes_billed
# DBT_DOMAIN_BIGQUERY_THREADS=4
# DBT_DOMAIN_BIGQUERY_TIMEOUT_SECONDS=300
# DBT_DOMAIN_BIGQUERY_PRIORITY=interactive
# DBT_DOMAIN_BIGQUERY_MAX_BYTES_BILLED=0

# JSON service account (секрет). Не коммитить.
# DBT_ENV_SECRET_DOMAIN_BIGQUERY_KEYFILE_JSON='{"type":"service_account",...}'
DBT_ENV_SECRET_DOMAIN_BIGQUERY_KEYFILE_JSON=

