# dbt-template (BigQuery). Копировать в .env. Секреты не коммитить.

DBT_PROJECT_NAME=project_name

# --- project_name (dev) ---
DBT_BIGQUERY_PROJECT=your-gcp-project-id
DBT_BIGQUERY_DATASET=no_schema
DBT_BIGQUERY_LOCATION=europe-west3
DBT_BIGQUERY_THREADS=4
DBT_BIGQUERY_TIMEOUT_SECONDS=300
DBT_BIGQUERY_PRIORITY=interactive
DBT_BIGQUERY_MAX_BYTES_BILLED=0
DBT_ENV_SECRET_BIGQUERY_KEYFILE_JSON='{
  "type": "service_account",
  "project_id": "your-gcp-project-id",
  "private_key_id": "...",
  "private_key": "...",
  "client_email": "...",
  "client_id": "...",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token",
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
  "client_x509_cert_url": "https://www.googleapis.com/robot/v1/metadata/x509/...",
  "universe_domain": "googleapis.com"
}'

# project_name prod (включить таргет prod в profiles.yml)
# DBT_BIGQUERY_PROJECT_PROD=
# DBT_BIGQUERY_DATASET_PROD=
# DBT_BIGQUERY_LOCATION_PROD=
